<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="36sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Form Registrasi"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lengkapi data diri Anda"
                android:textSize="13sp"
                android:textColor="#DDEEFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card: Identitas -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤  Identitas Mahasiswa"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#3949AB"
                    android:layout_marginBottom="16dp" />

                <!-- Nama Lengkap -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Lengkap *"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan nama lengkap"
                    android:inputType="textPersonName|textCapWords"
                    android:background="@drawable/bg_edittext"
                    android:padding="14dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- NIM -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NIM *"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etNim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan NIM"
                    android:inputType="number"
                    android:background="@drawable/bg_edittext"
                    android:padding="14dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Program Studi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Program Studi *"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerProdi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spinner"
                    android:padding="14dp"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Jenis Kelamin -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚧  Jenis Kelamin *"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#3949AB"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/rgJenisKelamin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbLakiLaki"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Laki-laki"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:buttonTint="#3949AB" />

                    <RadioButton
                        android:id="@+id/rbPerempuan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Perempuan"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:buttonTint="#3949AB" />

                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Hobi -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯  Hobi (pilih satu atau lebih)"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#3949AB"
                    android:layout_marginBottom="12dp" />

                <CheckBox
                    android:id="@+id/cbMembaca"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📚  Membaca"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:buttonTint="#3949AB"
                    android:layout_marginBottom="6dp" />

                <CheckBox
                    android:id="@+id/cbOlahraga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚽  Olahraga"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:buttonTint="#3949AB"
                    android:layout_marginBottom="6dp" />

                <CheckBox
                    android:id="@+id/cbMusik"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎵  Musik"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:buttonTint="#3949AB"
                    android:layout_marginBottom="6dp" />

                <CheckBox
                    android:id="@+id/cbGaming"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎮  Gaming"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:buttonTint="#3949AB"
                    android:layout_marginBottom="6dp" />

                <CheckBox
                    android:id="@+id/cbMasak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🍳  Memasak"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:buttonTint="#3949AB" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tombol Submit -->
        <Button
            android:id="@+id/btnTampilkan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Tampilkan Profil  →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3949AB"
            android:stateListAnimator="@null"
            android:layout_marginBottom="30dp" />

    </LinearLayout>
</ScrollView>